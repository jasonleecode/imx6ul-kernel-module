baudrate=115200
console=ttymxc0,115200
image=zImage
fdt_file=imx6ul-14x14-evk.dtb
mmcdev=0
mmcpart=1
bootargs=console=${console} root=/dev/mmcblk0p2 rootwait rw
loadimage=fatload mmc ${mmcdev}:${mmcpart} ${loadaddr} ${image}
loadfdt=fatload mmc ${mmcdev}:${mmcpart} ${fdt_addr} ${fdt_file}
bootcmd=mmc dev ${mmcdev}; run loadimage; run loadfdt; bootz ${loadaddr} - ${fdt_addr}
